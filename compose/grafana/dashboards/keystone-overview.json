        { "expr": "hikaricp_connections_active{application=\"keystone\"}", "legendFormat": "active", "refId": "A" },
        { "expr": "hikaricp_connections_idle{application=\"keystone\"}", "legendFormat": "idle", "refId": "B" }
      ]
    }
